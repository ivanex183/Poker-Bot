# Google Cloud Vision API
# Set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account JSON key
# Example: GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account-key.json

# Analysis settings
ANALYSIS_INTERVAL=3  # seconds between screenshots
SCREENSHOT_REGION=None  # None for full screen, or (x1, y1, x2, y2) for specific region
